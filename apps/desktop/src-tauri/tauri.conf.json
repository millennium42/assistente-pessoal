{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Assistente Pessoal",
  "version": "0.2.0",
  "identifier": "br.dev.assistentepessoal",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Assistente Pessoal",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["../../dist-sidecar/assistente-pessoal-api"]
  }
}
